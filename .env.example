# Copy this file to .env and fill real values. Do not commit .env.

ENVIRONMENT=local
CORS_ORIGINS=["http://localhost:3000"]
REDIS_URL=redis://localhost:6379/0

# Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Frontend-safe values only. Never place service-role credentials in NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

SUPABASE_VIDEO_BUCKET=videos
SUPABASE_STORAGE_BUCKET=violations

# Optional: direct Postgres URL for CLI/admin scripts only. Backend services do not read DB_URL.
DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

DUCKDNS_TOKEN=