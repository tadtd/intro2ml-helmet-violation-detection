# CVAT_USERNAME=
# CVAT_PASSWORD=

# Local Supabase development project. Keep real values only in untracked .env.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_STORAGE_BUCKET=violations
SUPABASE_VIDEO_BUCKET=videos

# Frontend-safe values only. Never place service-role credentials in NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Local shell default. docker-compose.yml overrides this to redis://redis:6379/0.
REDIS_URL=redis://localhost:6379/0
ENVIRONMENT=local
